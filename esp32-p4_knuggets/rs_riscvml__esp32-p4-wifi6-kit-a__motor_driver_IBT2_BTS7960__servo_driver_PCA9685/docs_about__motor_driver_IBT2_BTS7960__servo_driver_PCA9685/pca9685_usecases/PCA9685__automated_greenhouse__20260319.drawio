  <diagram id="greenhouse" name="PCA9685 — Automated Greenhouse">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;PCA9685: Automated Greenhouse — Vents, Louvers, Water Valves&lt;/b&gt;&lt;br&gt;9 servo channels driven by temperature, humidity, and soil moisture rules" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1"><mxGeometry x="220" y="20" width="660" height="40" as="geometry"/></mxCell>
        <mxCell id="sensors" value="&lt;b&gt;Sensors:&lt;/b&gt;&lt;br&gt;DHT22 (temp/humid)&lt;br&gt;Soil moisture × 3&lt;br&gt;Light sensor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="80" y="90" width="140" height="80" as="geometry"/></mxCell>
        <mxCell id="esp" value="&lt;b&gt;ESP32-P4&lt;/b&gt;&lt;br&gt;Rule engine&lt;br&gt;I2C → PCA9685&lt;br&gt;Wi-Fi dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="300" y="85" width="160" height="80" as="geometry"/></mxCell>
        <mxCell id="pca" value="&lt;b&gt;PCA9685&lt;/b&gt;&lt;br&gt;(0x40)&lt;br&gt;9 channels active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1"><mxGeometry x="550" y="85" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="vents" value="&lt;b&gt;CH0–CH3&lt;/b&gt;&lt;br&gt;Roof Vent Servos&lt;br&gt;(4 sections)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="790" y="70" width="140" height="50" as="geometry"/></mxCell>
        <mxCell id="louv" value="&lt;b&gt;CH4–CH5&lt;/b&gt;&lt;br&gt;Side Louver Servos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="790" y="130" width="140" height="40" as="geometry"/></mxCell>
        <mxCell id="water" value="&lt;b&gt;CH6–CH8&lt;/b&gt;&lt;br&gt;Water Valve Servos&lt;br&gt;(3 zones)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="790" y="180" width="140" height="50" as="geometry"/></mxCell>
        <mxCell id="e1" style="strokeColor=#9673a6;strokeWidth=2;" edge="1" source="sensors" target="esp" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="esp" target="pca" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="strokeColor=#82b366;strokeWidth=2;" edge="1" source="pca" target="vents" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="strokeColor=#82b366;strokeWidth=2;" edge="1" source="pca" target="louv" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="strokeColor=#82b366;strokeWidth=2;" edge="1" source="pca" target="water" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rules" value="&lt;b&gt;Rule Engine:&lt;/b&gt;&lt;hr&gt;&lt;table cellpadding=&quot;4&quot; style=&quot;font-size:10px;&quot;&gt;&lt;tr style=&quot;background:#1a1a1a;color:white;&quot;&gt;&lt;td&gt;&lt;b&gt;Condition&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Action&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8cecc;&quot;&gt;&lt;td&gt;temp &gt; 30°C&lt;/td&gt;&lt;td&gt;Open roof vents (CH0–CH3 → 90°)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;temp &gt; 35°C&lt;/td&gt;&lt;td&gt;Open louvers too (CH4–CH5 → 90°)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#d5e8d4;&quot;&gt;&lt;td&gt;temp &lt; 20°C&lt;/td&gt;&lt;td&gt;Close all vents + louvers (→ 0°)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;humidity &lt; 40%&lt;/td&gt;&lt;td&gt;Open water valves (CH6–CH8 → 90°)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#dae8fc;&quot;&gt;&lt;td&gt;soil moisture &gt; 60%&lt;/td&gt;&lt;td&gt;Close water valves (→ 0°)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;night time&lt;/td&gt;&lt;td&gt;Close all, water zone rotation&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;" vertex="1" parent="1"><mxGeometry x="80" y="260" width="420" height="200" as="geometry"/></mxCell>
        <mxCell id="ctx" value="&lt;b&gt;Applied to agrarobotics.com:&lt;/b&gt; Smart greenhouse product. Per-zone climate control. Dashboard via ESP32-P4 Wi-Fi AP." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="480" width="850" height="30" as="geometry"/></mxCell>
      </root>
