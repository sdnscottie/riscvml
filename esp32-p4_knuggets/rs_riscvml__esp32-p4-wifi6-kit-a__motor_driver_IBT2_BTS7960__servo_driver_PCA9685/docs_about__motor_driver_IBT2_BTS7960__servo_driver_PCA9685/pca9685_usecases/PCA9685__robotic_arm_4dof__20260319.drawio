<mxfile host="app.diagrams.net" modified="2026-03-19T00:00:00.000Z" agent="CC" version="24.0.0">
  <diagram id="arm" name="PCA9685 — 4-DOF Robotic Arm">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;PCA9685: 4-DOF Robotic Arm — Pick and Place&lt;/b&gt;&lt;br&gt;Base rotation, shoulder, elbow, gripper — inverse kinematics" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1"><mxGeometry x="300" y="20" width="500" height="40" as="geometry"/></mxCell>
        <mxCell id="esp" value="&lt;b&gt;ESP32-P4&lt;/b&gt;&lt;br&gt;I2C: GPIO 21/20&lt;br&gt;IK solver" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="100" width="150" height="70" as="geometry"/></mxCell>
        <mxCell id="pca" value="&lt;b&gt;PCA9685&lt;/b&gt; (0x40)&lt;br&gt;CH0–CH3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="330" y="100" width="150" height="60" as="geometry"/></mxCell>
        <mxCell id="ch0" value="&lt;b&gt;CH0: Base&lt;/b&gt;&lt;br&gt;MG996R (rotation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="580" y="80" width="150" height="40" as="geometry"/></mxCell>
        <mxCell id="ch1" value="&lt;b&gt;CH1: Shoulder&lt;/b&gt;&lt;br&gt;MG996R (lift)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="580" y="130" width="150" height="40" as="geometry"/></mxCell>
        <mxCell id="ch2" value="&lt;b&gt;CH2: Elbow&lt;/b&gt;&lt;br&gt;MG996R (extend)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="580" y="180" width="150" height="40" as="geometry"/></mxCell>
        <mxCell id="ch3" value="&lt;b&gt;CH3: Gripper&lt;/b&gt;&lt;br&gt;SG90 (open/close)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="580" y="230" width="150" height="40" as="geometry"/></mxCell>
        <mxCell id="e1" value="I2C" style="strokeColor=#6c8ebf;strokeWidth=2;fontSize=10;" edge="1" source="esp" target="pca" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="strokeColor=#82b366;strokeWidth=2;" edge="1" source="pca" target="ch0" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="strokeColor=#82b366;strokeWidth=2;" edge="1" source="pca" target="ch1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="strokeColor=#82b366;strokeWidth=2;" edge="1" source="pca" target="ch2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="strokeColor=#82b366;strokeWidth=2;" edge="1" source="pca" target="ch3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="seq" value="&lt;b&gt;Pick-and-Place Sequence:&lt;/b&gt;&lt;hr&gt;1. HOME → Base 90°, Shoulder 45°, Elbow 90°, Gripper OPEN&lt;br&gt;2. REACH → IK: target (x,y) → joint angles&lt;br&gt;3. GRIP → Gripper CLOSE (CH3 → 30°)&lt;br&gt;4. LIFT → Shoulder up (CH1 → 90°)&lt;br&gt;5. ROTATE → Base to drop zone (CH0 → 0°)&lt;br&gt;6. PLACE → Lower + Gripper OPEN&lt;br&gt;7. HOME → return to start" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="320" width="400" height="150" as="geometry"/></mxCell>
        <mxCell id="ik" value="&lt;b&gt;Inverse Kinematics:&lt;/b&gt;&lt;hr&gt;Input: target (x, y) in mm&lt;br&gt;Output: shoulder angle θ1, elbow angle θ2&lt;br&gt;&lt;br&gt;θ2 = acos((x²+y²-L1²-L2²) / (2·L1·L2))&lt;br&gt;θ1 = atan2(y,x) - atan2(L2·sin(θ2), L1+L2·cos(θ2))&lt;br&gt;&lt;br&gt;L1 = shoulder-to-elbow, L2 = elbow-to-gripper" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="530" y="320" width="350" height="140" as="geometry"/></mxCell>
        <mxCell id="ctx" value="&lt;b&gt;Applied to agrarobotics.com:&lt;/b&gt; Seedling pick-and-place, soil sample collection arm, fruit harvesting" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="490" width="800" height="30" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>