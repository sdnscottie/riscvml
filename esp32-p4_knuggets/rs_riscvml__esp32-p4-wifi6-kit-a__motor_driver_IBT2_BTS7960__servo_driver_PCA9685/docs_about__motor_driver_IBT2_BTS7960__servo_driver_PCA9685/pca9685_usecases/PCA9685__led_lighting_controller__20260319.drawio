<mxfile host="app.diagrams.net" modified="2026-03-19T00:00:00.000Z" agent="CC" version="24.0.0">
  <diagram id="led" name="PCA9685 — 16-Channel LED Lighting Controller">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;PCA9685: 16-Channel LED Brightness Controller (Grow Lights)&lt;/b&gt;&lt;br&gt;NOT servo mode — 1000Hz PWM, MOSFET drivers, 12-bit dimming (4096 levels)" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="700" height="40" as="geometry"/></mxCell>
        <mxCell id="esp" value="&lt;b&gt;ESP32-P4&lt;/b&gt;&lt;br&gt;I2C: GPIO 21/20&lt;br&gt;Light schedule&lt;br&gt;Spectrum control" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="90" width="160" height="80" as="geometry"/></mxCell>
        <mxCell id="pca" value="&lt;b&gt;PCA9685&lt;/b&gt;&lt;br&gt;(0x40)&lt;br&gt;&lt;b&gt;1000Hz&lt;/b&gt; (not 50Hz!)&lt;br&gt;16 PWM outputs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;" vertex="1" parent="1"><mxGeometry x="340" y="85" width="160" height="80" as="geometry"/></mxCell>
        <mxCell id="mosfets" value="&lt;b&gt;16x MOSFET Drivers&lt;/b&gt;&lt;br&gt;(IRLZ44N or AO3400)&lt;br&gt;&lt;br&gt;PCA9685 output (5V logic)&lt;br&gt;→ MOSFET gate&lt;br&gt;→ switches 12V LED strip" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;" vertex="1" parent="1"><mxGeometry x="600" y="80" width="200" height="100" as="geometry"/></mxCell>
        <mxCell id="leds" value="&lt;b&gt;16x LED Strips&lt;/b&gt;&lt;br&gt;12V, various spectra:&lt;br&gt;Red (660nm) — bloom&lt;br&gt;Blue (450nm) — veg&lt;br&gt;White — general&lt;br&gt;UV — sterilization" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=center;" vertex="1" parent="1"><mxGeometry x="900" y="75" width="160" height="100" as="geometry"/></mxCell>
        <mxCell id="psu" value="&lt;b&gt;12V LED&lt;br&gt;Supply&lt;/b&gt;&lt;br&gt;(10A+)" style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1"><mxGeometry x="600" y="210" width="150" height="45" as="geometry"/></mxCell>
        <mxCell id="e1" style="strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="esp" target="pca" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="strokeColor=#d6b656;strokeWidth=2;" edge="1" source="pca" target="mosfets" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="strokeColor=#82b366;strokeWidth=3;" edge="1" source="mosfets" target="leds" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="note" value="&lt;b&gt;Why MOSFET drivers?&lt;/b&gt; PCA9685 outputs max ~25mA at 5V. LED strips draw 1–3A per channel at 12V.&lt;br&gt;MOSFET sits between PCA9685 and LED strip: Gate ← PCA output, Drain ← LED strip, Source ← GND." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="290" width="550" height="50" as="geometry"/></mxCell>
        <mxCell id="schedule" value="&lt;b&gt;Grow Light Schedule:&lt;/b&gt;&lt;hr&gt;&lt;b&gt;Vegetative:&lt;/b&gt; 18h light / 6h dark, blue-heavy spectrum&lt;br&gt;&lt;b&gt;Flowering:&lt;/b&gt; 12h light / 12h dark, red-heavy spectrum&lt;br&gt;&lt;b&gt;Dawn/dusk simulation:&lt;/b&gt; 30min gradual ramp up/down (12-bit smooth fade)&lt;br&gt;&lt;b&gt;UV burst:&lt;/b&gt; 15min sterilization cycle (daily)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="360" width="450" height="100" as="geometry"/></mxCell>
        <mxCell id="ctx" value="&lt;b&gt;Applied to agrarobotics.com:&lt;/b&gt; Indoor vertical farming, greenhouse supplemental lighting, spectrum-tuned grow rooms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="480" width="850" height="30" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>