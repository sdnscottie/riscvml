<mxfile host="app.diagrams.net" modified="2026-03-19T00:00:00.000Z" agent="CC" version="24.0.0">
  <diagram id="hexapod" name="PCA9685 — Hexapod Walking Robot">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;PCA9685: Hexapod Walking Robot — 18 Servos, 2x Daisy-Chained&lt;/b&gt;&lt;br&gt;6 legs × 3 joints = 18 servos — PCA9685 #1 (0x40) + PCA9685 #2 (0x41)" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="700" height="40" as="geometry"/></mxCell>
        <mxCell id="esp" value="&lt;b&gt;ESP32-P4&lt;/b&gt;&lt;br&gt;I2C Bus 1&lt;br&gt;GPIO 21 (SDA)&lt;br&gt;GPIO 20 (SCL)&lt;br&gt;&lt;br&gt;Gait controller" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="90" width="160" height="110" as="geometry"/></mxCell>
        <mxCell id="pca1" value="&lt;b&gt;PCA9685 #1&lt;/b&gt;&lt;br&gt;(0x40)&lt;br&gt;CH0–CH8&lt;br&gt;Legs 1–3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;" vertex="1" parent="1"><mxGeometry x="350" y="80" width="140" height="70" as="geometry"/></mxCell>
        <mxCell id="pca2" value="&lt;b&gt;PCA9685 #2&lt;/b&gt;&lt;br&gt;(0x41)&lt;br&gt;CH0–CH8&lt;br&gt;Legs 4–6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;" vertex="1" parent="1"><mxGeometry x="350" y="170" width="140" height="70" as="geometry"/></mxCell>
        <mxCell id="legs" value="&lt;b&gt;18 Servos (SG90)&lt;/b&gt;&lt;br&gt;3 per leg:&lt;br&gt;Coxa (hip rotate)&lt;br&gt;Femur (thigh lift)&lt;br&gt;Tibia (knee extend)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=center;" vertex="1" parent="1"><mxGeometry x="600" y="100" width="160" height="90" as="geometry"/></mxCell>
        <mxCell id="e1" value="I2C" style="strokeColor=#6c8ebf;strokeWidth=2;fontSize=10;" edge="1" source="esp" target="pca1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1b" value="daisy" style="strokeColor=#d6b656;strokeWidth=2;fontSize=9;" edge="1" source="pca1" target="pca2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="strokeColor=#82b366;strokeWidth=2;" edge="1" source="pca1" target="legs" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="strokeColor=#82b366;strokeWidth=2;" edge="1" source="pca2" target="legs" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ch_table" value="&lt;table cellpadding=&quot;4&quot; style=&quot;font-size:10px;border-collapse:collapse;&quot;&gt;&lt;tr style=&quot;background:#1a1a1a;color:white;&quot;&gt;&lt;td&gt;&lt;b&gt;PCA&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;CH&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Leg&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Joint&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#fff2cc;&quot;&gt;&lt;td&gt;#1&lt;/td&gt;&lt;td&gt;0,1,2&lt;/td&gt;&lt;td&gt;Leg 1 (FR)&lt;/td&gt;&lt;td&gt;Coxa,Femur,Tibia&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;#1&lt;/td&gt;&lt;td&gt;3,4,5&lt;/td&gt;&lt;td&gt;Leg 2 (MR)&lt;/td&gt;&lt;td&gt;Coxa,Femur,Tibia&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#fff2cc;&quot;&gt;&lt;td&gt;#1&lt;/td&gt;&lt;td&gt;6,7,8&lt;/td&gt;&lt;td&gt;Leg 3 (BR)&lt;/td&gt;&lt;td&gt;Coxa,Femur,Tibia&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;#2&lt;/td&gt;&lt;td&gt;0,1,2&lt;/td&gt;&lt;td&gt;Leg 4 (FL)&lt;/td&gt;&lt;td&gt;Coxa,Femur,Tibia&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#fff2cc;&quot;&gt;&lt;td&gt;#2&lt;/td&gt;&lt;td&gt;3,4,5&lt;/td&gt;&lt;td&gt;Leg 5 (ML)&lt;/td&gt;&lt;td&gt;Coxa,Femur,Tibia&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;#2&lt;/td&gt;&lt;td&gt;6,7,8&lt;/td&gt;&lt;td&gt;Leg 6 (BL)&lt;/td&gt;&lt;td&gt;Coxa,Femur,Tibia&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;" vertex="1" parent="1"><mxGeometry x="80" y="280" width="340" height="190" as="geometry"/></mxCell>
        <mxCell id="gait" value="&lt;b&gt;Tripod Gait Pattern:&lt;/b&gt;&lt;hr&gt;&lt;b&gt;Phase A:&lt;/b&gt; Legs 1,5,3 lift + swing forward&lt;br&gt;            Legs 4,2,6 push backward (on ground)&lt;br&gt;&lt;b&gt;Phase B:&lt;/b&gt; Swap — 4,2,6 lift + swing&lt;br&gt;            1,5,3 push backward&lt;br&gt;&lt;br&gt;Always 3 legs on ground = stable.&lt;br&gt;&lt;br&gt;&lt;b&gt;I2C daisy-chain:&lt;/b&gt; SDA/SCL run from&lt;br&gt;PCA #1 output pins to PCA #2 input pins.&lt;br&gt;Set A0 jumper on #2 → address 0x41." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="470" y="280" width="300" height="190" as="geometry"/></mxCell>
        <mxCell id="pwr" value="&lt;b&gt;Power:&lt;/b&gt; 18 servos × 500mA peak = 9A. Use 5V 10A supply on V+ terminals. DO NOT power from ESP32." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="490" width="690" height="30" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>