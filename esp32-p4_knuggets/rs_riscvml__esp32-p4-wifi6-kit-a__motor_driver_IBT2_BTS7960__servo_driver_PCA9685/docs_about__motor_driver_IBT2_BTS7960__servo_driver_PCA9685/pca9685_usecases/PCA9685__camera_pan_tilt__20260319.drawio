<mxfile host="app.diagrams.net" modified="2026-03-19T00:00:00.000Z" agent="CC" version="24.0.0">
  <diagram id="pantilt" name="PCA9685 — Camera Pan/Tilt (Bird Detection)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;PCA9685: Camera Pan/Tilt Mount — Bird Detection Tracking&lt;/b&gt;&lt;br&gt;ML detection → bounding box center → servo angle → track target" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1"><mxGeometry x="250" y="20" width="600" height="40" as="geometry"/></mxCell>
        <mxCell id="cam" value="&lt;b&gt;MIPI-CSI&lt;br&gt;Camera&lt;/b&gt;&lt;br&gt;(on P4)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="80" y="100" width="100" height="70" as="geometry"/></mxCell>
        <mxCell id="esp" value="&lt;b&gt;ESP32-P4&lt;/b&gt;&lt;br&gt;esp-dl inference&lt;br&gt;→ bounding box&lt;br&gt;→ angle calc&lt;br&gt;I2C: GPIO 21/20" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="250" y="85" width="190" height="110" as="geometry"/></mxCell>
        <mxCell id="pca" value="&lt;b&gt;PCA9685&lt;/b&gt;&lt;br&gt;(0x40)&lt;br&gt;CH0 = Pan&lt;br&gt;CH1 = Tilt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" vertex="1" parent="1"><mxGeometry x="530" y="90" width="140" height="80" as="geometry"/></mxCell>
        <mxCell id="pan" value="&lt;b&gt;Pan Servo&lt;/b&gt;&lt;br&gt;(0–180°)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="760" y="80" width="110" height="45" as="geometry"/></mxCell>
        <mxCell id="tilt" value="&lt;b&gt;Tilt Servo&lt;/b&gt;&lt;br&gt;(0–180°)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="760" y="140" width="110" height="45" as="geometry"/></mxCell>
        <mxCell id="e1" style="strokeColor=#9673a6;strokeWidth=2;" edge="1" source="cam" target="esp" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="I2C" style="strokeColor=#6c8ebf;strokeWidth=2;fontSize=10;" edge="1" source="esp" target="pca" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="CH0" style="strokeColor=#82b366;strokeWidth=2;fontSize=9;" edge="1" source="pca" target="pan" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="CH1" style="strokeColor=#82b366;strokeWidth=2;fontSize=9;" edge="1" source="pca" target="tilt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="pipeline" value="&lt;b&gt;Tracking Pipeline:&lt;/b&gt;&lt;hr&gt;1. Camera frame → esp-dl bird detection → bounding box (x, y, w, h)&lt;br&gt;2. Box center: cx = x + w/2, cy = y + h/2&lt;br&gt;3. Error: pan_err = cx - frame_center_x, tilt_err = cy - frame_center_y&lt;br&gt;4. PID controller → servo angle adjustment (smooth tracking, no jitter)&lt;br&gt;5. PCA9685 CH0 ← new pan angle, CH1 ← new tilt angle&lt;br&gt;6. Log detection + servo position to riscvml_detect.db" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="240" width="790" height="120" as="geometry"/></mxCell>
        <mxCell id="ctx" value="&lt;b&gt;Integration:&lt;/b&gt; crittercam / secure_wap_streamer project. Wi-Fi API: /api/servo {pan: 0–180, tilt: 0–180}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="380" width="790" height="30" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>