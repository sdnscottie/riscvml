<mxfile host="app.diagrams.net" modified="2026-03-19T00:00:00.000Z" agent="CC" version="24.0.0">
  <diagram id="drill" name="BTS7960 — Drill Trigger Replacement">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;BTS7960: Variable Speed Drill Trigger Replacement&lt;/b&gt;&lt;br&gt;ESP32-P4 PWM replaces mechanical trigger — confirmed brushed motor at 19V" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1"><mxGeometry x="300" y="20" width="500" height="40" as="geometry"/></mxCell>
        <mxCell id="esp" value="&lt;b&gt;ESP32-P4&lt;/b&gt;&lt;br&gt;GPIO 4 → RPWM (speed)&lt;br&gt;GPIO 5 → LPWM (LOW)&lt;br&gt;GPIO 32 → R_EN (HIGH)&lt;br&gt;GPIO 22 → L_EN (HIGH)&lt;br&gt;3V3 → VCC&lt;br&gt;GND → GND" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="100" width="220" height="130" as="geometry"/></mxCell>
        <mxCell id="ibt" value="&lt;b&gt;IBT-2 / BTS7960&lt;/b&gt;&lt;br&gt;43A, 6–27V&lt;br&gt;PWM 25kHz&lt;br&gt;&lt;br&gt;VIN ← 19V drill battery&lt;br&gt;B+/B- → drill motor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="420" y="100" width="220" height="130" as="geometry"/></mxCell>
        <mxCell id="motor" value="&lt;b&gt;Drill Motor&lt;/b&gt;&lt;br&gt;(Brushed DC)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="110" width="140" height="70" as="geometry"/></mxCell>
        <mxCell id="bat" value="&lt;b&gt;Drill Battery&lt;br&gt;19V&lt;/b&gt;" style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="420" y="270" width="220" height="50" as="geometry"/></mxCell>
        <mxCell id="e1" value="4 control wires" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;fontSize=10;" edge="1" source="esp" target="ibt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="B+/B-" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=3;fontSize=10;" edge="1" source="ibt" target="motor" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="19V" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;strokeWidth=2;fontSize=10;" edge="1" source="bat" target="ibt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fluke" value="&lt;b&gt;Fluke DMM Measurements:&lt;/b&gt;&lt;hr&gt;Trigger released: 0V DC&lt;br&gt;Light press: ~1V DC&lt;br&gt;Full press: ~19V DC&lt;br&gt;&lt;br&gt;→ Confirmed: brushed motor,&lt;br&gt;variable-voltage trigger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="760" y="220" width="220" height="130" as="geometry"/></mxCell>
        <mxCell id="duty" value="&lt;table cellpadding=&quot;6&quot; style=&quot;font-size:11px;border-collapse:collapse;&quot;&gt;&lt;tr style=&quot;background:#1a1a1a;color:white;&quot;&gt;&lt;td&gt;&lt;b&gt;PWM Duty&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Motor Voltage&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Trigger Equiv&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f5f5f5;&quot;&gt;&lt;td&gt;0%&lt;/td&gt;&lt;td&gt;0V&lt;/td&gt;&lt;td&gt;Released&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;5%&lt;/td&gt;&lt;td&gt;~1V&lt;/td&gt;&lt;td&gt;Light press&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f5f5f5;&quot;&gt;&lt;td&gt;50%&lt;/td&gt;&lt;td&gt;~9.5V&lt;/td&gt;&lt;td&gt;Half pull&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;100%&lt;/td&gt;&lt;td&gt;~19V&lt;/td&gt;&lt;td&gt;Full press&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;" vertex="1" parent="1"><mxGeometry x="80" y="370" width="300" height="140" as="geometry"/></mxCell>
        <mxCell id="fwd" value="&lt;b&gt;Forward-only operation:&lt;/b&gt;&lt;br&gt;RPWM = PWM 0–100% (speed)&lt;br&gt;LPWM = LOW (not used)&lt;br&gt;R_EN = HIGH, L_EN = HIGH" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="420" y="370" width="250" height="80" as="geometry"/></mxCell>
        <mxCell id="safety" value="&lt;b&gt;Safety:&lt;/b&gt; Keep hands clear of drill chuck. Use thick gauge wire (14 AWG min).&lt;br&gt;Drill motors pull 10–30A startup current — IBT-2 handles 43A continuous." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="530" width="900" height="40" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>