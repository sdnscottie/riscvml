<mxfile host="app.diagrams.net" modified="2026-03-19T00:00:00.000Z" agent="CC" version="24.0.0">
  <diagram id="ev" name="BTS7960 — Electric Vehicle Throttle">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;BTS7960: E-Bike / Go-Kart / Scooter Throttle Control&lt;/b&gt;&lt;br&gt;24V battery, thumb throttle → ADC → PWM speed, regen braking, speed limiting" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="700" height="40" as="geometry"/></mxCell>
        <mxCell id="throttle" value="&lt;b&gt;Thumb Throttle&lt;/b&gt;&lt;br&gt;(Hall effect)&lt;br&gt;0–3.3V analog&lt;br&gt;→ ADC input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="100" width="130" height="80" as="geometry"/></mxCell>
        <mxCell id="esp" value="&lt;b&gt;ESP32-P4&lt;/b&gt;&lt;br&gt;&lt;br&gt;ADC ← throttle (0–3.3V)&lt;br&gt;ADC ← battery voltage (divider)&lt;br&gt;GPIO 4 → RPWM (drive)&lt;br&gt;GPIO 5 → LPWM (regen brake)&lt;br&gt;GPIO 27 → R_EN&lt;br&gt;GPIO 22 → L_EN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="280" y="85" width="230" height="140" as="geometry"/></mxCell>
        <mxCell id="ibt" value="&lt;b&gt;BTS7960&lt;/b&gt;&lt;br&gt;24V, 43A" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;" vertex="1" parent="1"><mxGeometry x="600" y="100" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="motor" value="&lt;b&gt;Brushed DC&lt;br&gt;Drive Motor&lt;/b&gt;&lt;br&gt;24V" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="830" y="90" width="130" height="70" as="geometry"/></mxCell>
        <mxCell id="bat" value="&lt;b&gt;24V Battery&lt;br&gt;Pack&lt;/b&gt;" style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="580" y="210" width="180" height="45" as="geometry"/></mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;strokeWidth=2;" edge="1" source="throttle" target="esp" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="esp" target="ibt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=3;" edge="1" source="ibt" target="motor" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="modes" value="&lt;table cellpadding=&quot;5&quot; style=&quot;font-size:11px;border-collapse:collapse;&quot;&gt;&lt;tr style=&quot;background:#1a1a1a;color:white;&quot;&gt;&lt;td&gt;&lt;b&gt;Mode&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Max PWM&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Max Speed&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#d5e8d4;&quot;&gt;&lt;td&gt;Eco&lt;/td&gt;&lt;td&gt;40%&lt;/td&gt;&lt;td&gt;~10 km/h&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Normal&lt;/td&gt;&lt;td&gt;70%&lt;/td&gt;&lt;td&gt;~20 km/h&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#fff2cc;&quot;&gt;&lt;td&gt;Sport&lt;/td&gt;&lt;td&gt;100%&lt;/td&gt;&lt;td&gt;~30 km/h&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;" vertex="1" parent="1"><mxGeometry x="80" y="310" width="250" height="120" as="geometry"/></mxCell>
        <mxCell id="regen" value="&lt;b&gt;Regenerative Braking:&lt;/b&gt;&lt;hr&gt;Release throttle → RPWM=HIGH, LPWM=HIGH&lt;br&gt;Motor's back-EMF charges battery through H-bridge&lt;br&gt;&lt;br&gt;&lt;b&gt;Throttle mapping:&lt;/b&gt;&lt;br&gt;ADC 0–4095 → map to 0–max_pwm (mode-dependent)&lt;br&gt;Dead zone: ADC &lt; 200 = off (prevent creep)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="380" y="310" width="350" height="120" as="geometry"/></mxCell>
        <mxCell id="safety" value="&lt;b&gt;Safety:&lt;/b&gt; Battery voltage monitor (cutoff at 20V to prevent over-discharge). Throttle dead-zone. Current limiting via PWM cap." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="450" width="650" height="35" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>