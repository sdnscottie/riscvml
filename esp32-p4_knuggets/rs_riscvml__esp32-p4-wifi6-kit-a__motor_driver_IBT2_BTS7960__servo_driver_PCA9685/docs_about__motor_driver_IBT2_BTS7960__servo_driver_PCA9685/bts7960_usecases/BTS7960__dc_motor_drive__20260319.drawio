<mxfile host="app.diagrams.net" modified="2026-03-19T00:00:00.000Z" agent="CC" version="24.0.0">
  <diagram id="dc-drive-overview" name="BTS7960 — DC Motor Drive (Overview)">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="t" value="&lt;b&gt;BTS7960: DC Motor Drive — Application Use Cases&lt;/b&gt;&lt;br&gt;One H-bridge, many applications. Forward/reverse, variable speed, brake/coast." style="text;html=1;align=center;fontSize=18;" vertex="1" parent="1"><mxGeometry x="300" y="20" width="600" height="45" as="geometry"/></mxCell>

        <!-- Core block -->
        <mxCell id="core" value="&lt;b&gt;CORE: ESP32-P4 + BTS7960&lt;/b&gt;&lt;hr&gt;GPIO 4 → RPWM (forward)&lt;br&gt;GPIO 5 → LPWM (reverse)&lt;br&gt;GPIO 6 → R_EN&lt;br&gt;GPIO 22 → L_EN&lt;br&gt;VIN ← 6–27V supply&lt;br&gt;B+/B- → DC motor&lt;br&gt;&lt;br&gt;&lt;b&gt;43A continuous, PWM 25kHz&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1"><mxGeometry x="530" y="100" width="240" height="170" as="geometry"/></mxCell>

        <!-- ==================== SUB USE CASES ==================== -->

        <!-- 1. Robot Head/Arm Drive -->
        <mxCell id="uc1" value="&lt;b&gt;1. Robot Head / Arm Drive&lt;/b&gt;&lt;hr&gt;DC motor rotates robot head or arm joint&lt;br&gt;left/right (or up/down) via fwd/rev.&lt;br&gt;&lt;br&gt;&lt;b&gt;Motor:&lt;/b&gt; 12V DC gear motor (low RPM, high torque)&lt;br&gt;&lt;b&gt;Control:&lt;/b&gt; Position via timed PWM pulses&lt;br&gt;or feedback from rotary encoder.&lt;br&gt;&lt;b&gt;Speed:&lt;/b&gt; PWM 10–50% for slow, smooth motion&lt;br&gt;&lt;b&gt;Brake:&lt;/b&gt; RPWM=LPWM=HIGH to hold position&lt;br&gt;&lt;br&gt;&lt;i&gt;For animatronics, security bots,&lt;br&gt;teaching robots, scarecrow heads&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="60" y="100" width="280" height="210" as="geometry"/></mxCell>

        <!-- 2. Critter Scarer -->
        <mxCell id="uc2" value="&lt;b&gt;2. Critter Scarer / Deterrent&lt;/b&gt;&lt;hr&gt;Motor-driven decoy or noise maker that&lt;br&gt;activates when wildlife is detected.&lt;br&gt;&lt;br&gt;&lt;b&gt;Trigger:&lt;/b&gt; PIR sensor or ML camera detection&lt;br&gt;(esp-dl: bird/deer/rabbit classification)&lt;br&gt;&lt;b&gt;Action:&lt;/b&gt; Motor spins decoy owl/flag/arm&lt;br&gt;rapidly fwd/rev for 5–10 seconds&lt;br&gt;&lt;b&gt;Pattern:&lt;/b&gt; Randomized speed + direction&lt;br&gt;(animals habituate to predictable patterns)&lt;br&gt;&lt;b&gt;Power:&lt;/b&gt; Solar + battery (field deployment)&lt;br&gt;&lt;br&gt;&lt;i&gt;Protects crops, fish ponds, gardens.&lt;br&gt;Ties into bird detection capstone.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="60" y="340" width="280" height="240" as="geometry"/></mxCell>

        <!-- 3. Drawbridge / Trap Door -->
        <mxCell id="uc3" value="&lt;b&gt;3. Drawbridge / Trap Door / Gate&lt;/b&gt;&lt;hr&gt;DC motor raises/lowers a hinged panel:&lt;br&gt;drawbridge, chicken coop door, greenhouse&lt;br&gt;vent, loading ramp, animal trap door.&lt;br&gt;&lt;br&gt;&lt;b&gt;Forward:&lt;/b&gt; Motor winds cable/chain → door opens&lt;br&gt;&lt;b&gt;Reverse:&lt;/b&gt; Motor unwinds → door closes (gravity)&lt;br&gt;&lt;b&gt;Limit switches:&lt;/b&gt; Top (fully open) + Bottom (fully closed)&lt;br&gt;wired to R_EN/L_EN for hardware safety&lt;br&gt;&lt;b&gt;Soft start/stop:&lt;/b&gt; PWM ramp prevents slamming&lt;br&gt;&lt;b&gt;Timer:&lt;/b&gt; Auto-close after N minutes&lt;br&gt;&lt;br&gt;&lt;i&gt;Chicken coop: open at dawn, close at dusk&lt;br&gt;(light sensor or RTC schedule)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="380" y="340" width="280" height="260" as="geometry"/></mxCell>

        <!-- 4. Conveyor / Feed System -->
        <mxCell id="uc4" value="&lt;b&gt;4. Feed Dispenser / Conveyor&lt;/b&gt;&lt;hr&gt;Motor-driven auger or belt feeds material:&lt;br&gt;animal feed, seed, fertilizer, parts.&lt;br&gt;&lt;br&gt;&lt;b&gt;Forward:&lt;/b&gt; Dispense material&lt;br&gt;&lt;b&gt;Reverse:&lt;/b&gt; Clear jams&lt;br&gt;&lt;b&gt;Speed:&lt;/b&gt; Controls feed rate (g/min)&lt;br&gt;&lt;b&gt;Schedule:&lt;/b&gt; RTC or cron-based feeding times&lt;br&gt;&lt;b&gt;Sensor:&lt;/b&gt; Load cell measures hopper level&lt;br&gt;&lt;br&gt;&lt;i&gt;Automated chicken/livestock feeding,&lt;br&gt;seed drill, parts feeder&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="700" y="340" width="280" height="220" as="geometry"/></mxCell>

        <!-- 5. Turntable / Rotating Platform -->
        <mxCell id="uc5" value="&lt;b&gt;5. Turntable / Rotating Platform&lt;/b&gt;&lt;hr&gt;DC motor rotates a platform CW/CCW:&lt;br&gt;display turntable, sensor scanner,&lt;br&gt;solar panel rough-positioning.&lt;br&gt;&lt;br&gt;&lt;b&gt;CW:&lt;/b&gt; RPWM at low PWM (slow rotation)&lt;br&gt;&lt;b&gt;CCW:&lt;/b&gt; LPWM at low PWM&lt;br&gt;&lt;b&gt;Index:&lt;/b&gt; Hall sensor for home position&lt;br&gt;&lt;b&gt;Scan:&lt;/b&gt; Rotate 360°, stop at each quadrant&lt;br&gt;&lt;br&gt;&lt;i&gt;LiDAR/ultrasonic scanning platform,&lt;br&gt;product photography turntable&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1020" y="100" width="280" height="210" as="geometry"/></mxCell>

        <!-- 6. Tank Steering (existing) -->
        <mxCell id="uc6" value="&lt;b&gt;6. Tank Steering (Rover Drive)&lt;/b&gt;&lt;hr&gt;2x BTS7960 for differential drive.&lt;br&gt;See: BTS7960__dc_motor_robot_drive&lt;br&gt;&lt;br&gt;&lt;i&gt;Field inspection rover, autonomous&lt;br&gt;mowing robot, crop row navigator&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="1020" y="340" width="280" height="110" as="geometry"/></mxCell>

        <!-- Arrows from core -->
        <mxCell id="ea" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;dashed=1;" edge="1" source="core" target="uc1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="eb" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;dashed=1;" edge="1" source="core" target="uc2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ec" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;dashed=1;" edge="1" source="core" target="uc3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;dashed=1;" edge="1" source="core" target="uc4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ee" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;dashed=1;" edge="1" source="core" target="uc5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ef" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;dashed=1;" edge="1" source="core" target="uc6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Common pattern -->
        <mxCell id="pattern" value="&lt;b&gt;Common DC Motor Drive Pattern:&lt;/b&gt;&lt;hr&gt;&lt;table cellpadding=&quot;5&quot; style=&quot;font-size:11px;border-collapse:collapse;&quot;&gt;&lt;tr style=&quot;background:#1a1a1a;color:white;&quot;&gt;&lt;td&gt;&lt;b&gt;Action&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;RPWM&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;LPWM&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Result&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#d5e8d4;&quot;&gt;&lt;td&gt;Forward (variable)&lt;/td&gt;&lt;td&gt;PWM 0–100%&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;Motor CW at set speed&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Reverse (variable)&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;PWM 0–100%&lt;/td&gt;&lt;td&gt;Motor CCW at set speed&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8cecc;&quot;&gt;&lt;td&gt;Brake (active stop)&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;Motor shorts → rapid stop&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f5f5f5;&quot;&gt;&lt;td&gt;Coast (free spin)&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;Motor unpowered&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#fff2cc;&quot;&gt;&lt;td&gt;Disabled (safe)&lt;/td&gt;&lt;td&gt;any&lt;/td&gt;&lt;td&gt;any&lt;/td&gt;&lt;td&gt;R_EN=L_EN=LOW → Hi-Z&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;" vertex="1" parent="1"><mxGeometry x="60" y="640" width="500" height="190" as="geometry"/></mxCell>

        <!-- Safety -->
        <mxCell id="safety" value="&lt;b&gt;Universal Safety Rules:&lt;/b&gt;&lt;hr&gt;□ Limit switches on EN pins for position-limited actuators (doors, hoists)&lt;br&gt;□ Soft start/stop PWM ramp for mechanical loads (prevents slamming, cable shock)&lt;br&gt;□ Current monitoring via BTS7960 IS pins (detect stall = jam or overload)&lt;br&gt;□ Watchdog timer: if ESP32 stops responding, EN pins go LOW (motor stops)&lt;br&gt;□ E-stop button hardwired to EN pins (bypasses software entirely)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=15;" vertex="1" parent="1"><mxGeometry x="600" y="640" width="500" height="110" as="geometry"/></mxCell>

        <!-- Context -->
        <mxCell id="ctx" value="&lt;b&gt;Applied to agrarobotics.com:&lt;/b&gt; Critter scarer (ML-triggered), chicken coop door (dawn/dusk auto), feed dispenser (scheduled), field rover (tank drive)&lt;br&gt;&lt;b&gt;Applied to riscvml.org:&lt;/b&gt; Curriculum module: &quot;DC Motor Control Patterns&quot; — one BTS7960, six real-world applications, same GPIO wiring" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=15;" vertex="1" parent="1"><mxGeometry x="60" y="860" width="1040" height="50" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>