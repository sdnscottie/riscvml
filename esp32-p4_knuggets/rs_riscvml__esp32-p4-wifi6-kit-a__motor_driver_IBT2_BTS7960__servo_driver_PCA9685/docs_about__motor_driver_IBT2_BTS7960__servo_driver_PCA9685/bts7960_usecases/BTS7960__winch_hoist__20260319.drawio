<mxfile host="app.diagrams.net" modified="2026-03-19T00:00:00.000Z" agent="CC" version="24.0.0">
  <diagram id="winch" name="BTS7960 — Winch / Hoist Control">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;BTS7960: Winch / Hoist Lift &amp; Lower Control&lt;/b&gt;&lt;br&gt;12–24V DC motor — forward=raise, reverse=lower, limit switches, overload protection" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="700" height="40" as="geometry"/></mxCell>
        <mxCell id="esp" value="&lt;b&gt;ESP32-P4&lt;/b&gt;&lt;br&gt;GPIO 4 → RPWM (raise)&lt;br&gt;GPIO 5 → LPWM (lower)&lt;br&gt;GPIO 27 → R_EN&lt;br&gt;GPIO 22 → L_EN&lt;br&gt;ADC ← load cell (HX711)&lt;br&gt;GPIO ← top limit switch&lt;br&gt;GPIO ← bottom limit switch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="90" width="230" height="150" as="geometry"/></mxCell>
        <mxCell id="ibt" value="&lt;b&gt;BTS7960&lt;/b&gt;&lt;br&gt;12–24V&lt;br&gt;&lt;br&gt;Limit switches in&lt;br&gt;series with EN pins" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" vertex="1" parent="1"><mxGeometry x="420" y="100" width="170" height="100" as="geometry"/></mxCell>
        <mxCell id="motor" value="&lt;b&gt;Winch&lt;br&gt;Motor&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="700" y="105" width="120" height="60" as="geometry"/></mxCell>
        <mxCell id="top_sw" value="&lt;b&gt;TOP&lt;br&gt;Limit SW&lt;/b&gt;&lt;br&gt;(NC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1"><mxGeometry x="700" y="200" width="80" height="55" as="geometry"/></mxCell>
        <mxCell id="bot_sw" value="&lt;b&gt;BOTTOM&lt;br&gt;Limit SW&lt;/b&gt;&lt;br&gt;(NC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1"><mxGeometry x="800" y="200" width="80" height="55" as="geometry"/></mxCell>
        <mxCell id="load" value="&lt;b&gt;Load Cell&lt;/b&gt;&lt;br&gt;(HX711)&lt;br&gt;→ overload detect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1"><mxGeometry x="700" y="280" width="110" height="55" as="geometry"/></mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="esp" target="ibt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=3;" edge="1" source="ibt" target="motor" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="safety" value="&lt;b&gt;Safety Design:&lt;/b&gt;&lt;hr&gt;• &lt;b&gt;Limit switches (NC)&lt;/b&gt; wired in series with R_EN/L_EN → hardware hard-stop at top/bottom&lt;br&gt;• &lt;b&gt;Load cell (HX711)&lt;/b&gt; monitors weight — if &gt; max rating, ESP32 cuts PWM to 0&lt;br&gt;• &lt;b&gt;Current sensing&lt;/b&gt; via BTS7960 IS pins — stall current = cable jam, trigger E-stop&lt;br&gt;• &lt;b&gt;Soft start&lt;/b&gt; via PWM ramp — prevents cable shock loading" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="380" width="800" height="100" as="geometry"/></mxCell>
        <mxCell id="ctrl" value="&lt;table cellpadding=&quot;5&quot; style=&quot;font-size:11px;border-collapse:collapse;&quot;&gt;&lt;tr style=&quot;background:#1a1a1a;color:white;&quot;&gt;&lt;td&gt;&lt;b&gt;Command&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;RPWM&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;LPWM&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Result&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#d5e8d4;&quot;&gt;&lt;td&gt;Raise&lt;/td&gt;&lt;td&gt;PWM&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;Cable winds → load goes up&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Lower&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;PWM&lt;/td&gt;&lt;td&gt;Cable unwinds → load goes down&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8cecc;&quot;&gt;&lt;td&gt;Hold/Brake&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;Motor brakes → load holds position&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;" vertex="1" parent="1"><mxGeometry x="80" y="500" width="450" height="120" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>