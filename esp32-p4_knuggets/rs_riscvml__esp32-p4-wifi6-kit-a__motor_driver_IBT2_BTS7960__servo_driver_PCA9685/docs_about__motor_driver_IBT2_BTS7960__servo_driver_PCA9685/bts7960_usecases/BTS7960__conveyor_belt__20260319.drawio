<mxfile host="app.diagrams.net" modified="2026-03-19T00:00:00.000Z" agent="CC" version="24.0.0">
  <diagram id="conveyor" name="BTS7960 — Conveyor Belt Motor Control">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;BTS7960: Industrial Conveyor Belt Control&lt;/b&gt;&lt;br&gt;24V DC motor — forward/reverse, E-stop, soft start/stop ramp profiles" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1"><mxGeometry x="250" y="20" width="600" height="40" as="geometry"/></mxCell>
        <mxCell id="opt" value="&lt;b&gt;Optical Sensor&lt;/b&gt;&lt;br&gt;(object detect)&lt;br&gt;→ GPIO input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="80" y="90" width="120" height="70" as="geometry"/></mxCell>
        <mxCell id="estop" value="&lt;b&gt;E-STOP&lt;/b&gt;&lt;br&gt;(NC button)&lt;br&gt;→ R_EN/L_EN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1"><mxGeometry x="80" y="180" width="120" height="70" as="geometry"/></mxCell>
        <mxCell id="esp" value="&lt;b&gt;ESP32-P4&lt;/b&gt;&lt;br&gt;GPIO 4 → RPWM (fwd)&lt;br&gt;GPIO 5 → LPWM (rev)&lt;br&gt;Optical → GPIO input&lt;br&gt;&lt;br&gt;&lt;i&gt;R_EN/L_EN wired through&lt;br&gt;E-stop (hardware safety)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="280" y="90" width="220" height="130" as="geometry"/></mxCell>
        <mxCell id="ibt" value="&lt;b&gt;BTS7960&lt;/b&gt;&lt;br&gt;24V, fwd/rev&lt;br&gt;&lt;br&gt;E-stop → EN pins&lt;br&gt;(hardware cutoff)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" vertex="1" parent="1"><mxGeometry x="580" y="90" width="160" height="100" as="geometry"/></mxCell>
        <mxCell id="motor" value="&lt;b&gt;24V DC&lt;br&gt;Belt Motor&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="830" y="95" width="120" height="60" as="geometry"/></mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="esp" target="ibt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=3;" edge="1" source="ibt" target="motor" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ramp" value="&lt;b&gt;Soft Start/Stop Ramp:&lt;/b&gt;&lt;hr&gt;&lt;b&gt;Start:&lt;/b&gt; PWM ramps 0% → 100% over 2 seconds&lt;br&gt;&lt;b&gt;Stop:&lt;/b&gt; PWM ramps 100% → 0% over 2 seconds&lt;br&gt;&lt;b&gt;E-stop:&lt;/b&gt; Immediate hardware cutoff (EN pins go LOW)&lt;br&gt;&lt;br&gt;Prevents product damage from sudden starts/stops.&lt;br&gt;E-stop bypasses software — wired directly to BTS7960 enable pins." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="310" width="450" height="130" as="geometry"/></mxCell>
        <mxCell id="logic" value="&lt;b&gt;Conveyor Logic:&lt;/b&gt;&lt;hr&gt;1. Optical sensor detects object → start belt (fwd)&lt;br&gt;2. Object reaches end → stop belt&lt;br&gt;3. Operator presses reverse → belt runs backward&lt;br&gt;4. E-stop pressed → immediate hardware stop&lt;br&gt;5. API: /api/conveyor {speed, direction}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="580" y="310" width="370" height="120" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>