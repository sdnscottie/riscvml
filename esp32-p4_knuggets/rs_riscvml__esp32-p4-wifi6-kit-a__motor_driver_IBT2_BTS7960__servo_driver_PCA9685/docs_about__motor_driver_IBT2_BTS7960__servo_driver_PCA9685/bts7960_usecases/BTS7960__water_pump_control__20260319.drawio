<mxfile host="app.diagrams.net" modified="2026-03-19T00:00:00.000Z" agent="CC" version="24.0.0">
  <diagram id="pump" name="BTS7960 — Water Pump Control (Irrigation)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="t" value="&lt;b&gt;BTS7960: Solar-Powered Irrigation Pump Control&lt;/b&gt;&lt;br&gt;Soil moisture sensor → ESP32-P4 → BTS7960 → 12/24V DC pump — variable flow rate via PWM" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="700" height="40" as="geometry"/></mxCell>
        <mxCell id="sensor" value="&lt;b&gt;Soil Moisture&lt;br&gt;Sensor&lt;/b&gt;&lt;br&gt;(capacitive)&lt;br&gt;→ ADC input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="100" width="120" height="90" as="geometry"/></mxCell>
        <mxCell id="esp" value="&lt;b&gt;ESP32-P4&lt;/b&gt;&lt;br&gt;&lt;br&gt;ADC ← moisture sensor&lt;br&gt;GPIO 4 → RPWM (pump speed)&lt;br&gt;GPIO 5 → LPWM (LOW)&lt;br&gt;GPIO 6 → R_EN (HIGH)&lt;br&gt;GPIO 22 → L_EN (HIGH)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="260" y="90" width="220" height="130" as="geometry"/></mxCell>
        <mxCell id="ibt" value="&lt;b&gt;BTS7960&lt;/b&gt;&lt;br&gt;VIN ← 12/24V&lt;br&gt;B+/B- → pump" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;" vertex="1" parent="1"><mxGeometry x="560" y="100" width="150" height="70" as="geometry"/></mxCell>
        <mxCell id="pump" value="&lt;b&gt;DC Water&lt;br&gt;Pump&lt;/b&gt;&lt;br&gt;12/24V" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="790" y="95" width="120" height="70" as="geometry"/></mxCell>
        <mxCell id="solar" value="&lt;b&gt;Solar Panel&lt;br&gt;+ Battery&lt;/b&gt;&lt;br&gt;12/24V" style="shape=parallelogram;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1"><mxGeometry x="560" y="210" width="150" height="50" as="geometry"/></mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;strokeWidth=2;" edge="1" source="sensor" target="esp" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="esp" target="ibt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=3;" edge="1" source="ibt" target="pump" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="logic" value="&lt;b&gt;Auto-Irrigation Logic:&lt;/b&gt;&lt;hr&gt;1. Read soil moisture ADC every 60s&lt;br&gt;2. moisture &lt; 30% → pump ON at 80% PWM&lt;br&gt;3. moisture 30–50% → pump ON at 40% PWM&lt;br&gt;4. moisture &gt; 50% → pump OFF&lt;br&gt;5. Log readings to SQLite (time_use pattern)&lt;br&gt;6. Wi-Fi API: /api/pump/status, /api/pump/override" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="300" width="350" height="130" as="geometry"/></mxCell>
        <mxCell id="safety" value="&lt;b&gt;Safety:&lt;/b&gt; Run-dry protection (flow sensor or current monitoring). Timer cutoff (max 30min continuous)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="450" width="830" height="30" as="geometry"/></mxCell>
        <mxCell id="ctx" value="&lt;b&gt;Applied to agrarobotics.com:&lt;/b&gt; Per-zone drip irrigation, solar-powered field pump, greenhouse watering system" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="80" y="500" width="830" height="30" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
