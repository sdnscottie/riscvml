        <!-- 4-pin explanation -->
        <mxCell id="ibt2_4pin_note" value="&lt;b&gt;Screw Terminal Pin Explanation:&lt;/b&gt;&lt;br&gt;&lt;b&gt;B+&lt;/b&gt; = Battery/PSU positive (6–27V)&lt;br&gt;&lt;b&gt;B−&lt;/b&gt; = Battery/PSU negative (GND)&lt;br&gt;&lt;b&gt;M+&lt;/b&gt; = Motor positive lead&lt;br&gt;&lt;b&gt;M−&lt;/b&gt; = Motor negative lead&lt;br&gt;&lt;br&gt;&lt;i&gt;H-bridge switches B+ voltage&lt;br&gt;to M+/M− in fwd or rev polarity.&lt;br&gt;Use thick wire (14 AWG min).&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
