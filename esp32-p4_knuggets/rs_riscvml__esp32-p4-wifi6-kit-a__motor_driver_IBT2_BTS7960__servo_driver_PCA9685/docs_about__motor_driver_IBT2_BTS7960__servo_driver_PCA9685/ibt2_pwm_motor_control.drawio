          <mxGeometry x="100" y="1090" width="400" height="20" as="geometry"/>
        </mxCell>

        <!-- BRAKE diagram -->
        <mxCell id="brk_label" value="&lt;b&gt;BRAKE:&lt;/b&gt; RPWM = HIGH, LPWM = HIGH" style="text;html=1;align=center;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="810" width="480" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="brk_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="640" y="845" width="400" height="250" as="geometry"/>
        </mxCell>

        <mxCell id="brk_explain" value="Both LOW-side switches CLOSED.&lt;br&gt;Motor leads shorted together.&lt;br&gt;&lt;b&gt;Motor's back-EMF brakes itself.&lt;/b&gt;&lt;br&gt;&lt;br&gt;No current from battery — &lt;br&gt;the motor's own energy &lt;br&gt;dissipates through the switches." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="700" y="880" width="220" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="brk_flow" value="&lt;font color=&quot;#b85450&quot;&gt;&lt;b&gt;Motor shorts through both LOW switches → rapid stop&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="1090" width="400" height="20" as="geometry"/>
        </mxCell>

        <!-- ==================== SECTION 4: CONTROL TABLE ==================== -->
        <mxCell id="s4_bar" value="&lt;b&gt;4. CONTROL SUMMARY — ESP32-P4 Pin States&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="60" y="1130" width="1080" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="table" value="&lt;table cellpadding=&quot;8&quot; style=&quot;font-size:13px;border-collapse:collapse;&quot;&gt;&lt;tr style=&quot;background:#1a1a1a;color:white;&quot;&gt;&lt;td&gt;&lt;b&gt;Action&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;RPWM (GPIO 4)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;LPWM (GPIO 5)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;R_EN (GPIO 6)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;L_EN (GPIO 22)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Motor&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#d5e8d4;&quot;&gt;&lt;td&gt;&lt;b&gt;▶ Forward (variable)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;PWM 0–100%&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;Spins CW at set speed&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#dae8fc;&quot;&gt;&lt;td&gt;&lt;b&gt;◀ Reverse (variable)&lt;/b&gt;&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;PWM 0–100%&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;Spins CCW at set speed&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8cecc;&quot;&gt;&lt;td&gt;&lt;b&gt;⏹ Brake&lt;/b&gt;&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;Active stop (rapid)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f5f5f5;&quot;&gt;&lt;td&gt;&lt;b&gt;⏸ Coast&lt;/b&gt;&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;HIGH&lt;/td&gt;&lt;td&gt;Free spin (no power)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#fff2cc;&quot;&gt;&lt;td&gt;&lt;b&gt;⚡ Disabled&lt;/b&gt;&lt;/td&gt;&lt;td&gt;any&lt;/td&gt;&lt;td&gt;any&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;LOW&lt;/td&gt;&lt;td&gt;Off (safe — outputs Hi-Z)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=center;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="120" y="1180" width="960" height="200" as="geometry"/>
        </mxCell>

        <!-- ==================== SECTION 5: DRILL TRIGGER USE CASE ==================== -->
        <mxCell id="s5_bar" value="&lt;b&gt;5. DRILL TRIGGER REPLACEMENT — Your Setup&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9673a6;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="60" y="1400" width="1080" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="drill_before" value="&lt;b&gt;BEFORE (Original Drill)&lt;/b&gt;&lt;hr&gt;&lt;br&gt;Battery 19V → &lt;b&gt;Trigger&lt;/b&gt; → Motor&lt;br&gt;&lt;br&gt;Trigger = variable resistor&lt;br&gt;Light press → 1V → slow&lt;br&gt;Full press → 19V → full speed&lt;br&gt;&lt;br&gt;&lt;i&gt;Measured with Fluke DMM&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="1460" width="250" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="drill_arrow" value="&lt;b&gt;REPLACED BY&lt;/b&gt;" style="shape=singleArrow;whiteSpace=wrap;html=1;fillColor=#9673a6;fontColor=#ffffff;fontSize=12;arrowWidth=0.4;arrowSize=0.3;" vertex="1" parent="1">
          <mxGeometry x="380" y="1520" width="140" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="drill_after" value="&lt;b&gt;AFTER (ESP32-P4 + IBT-2)&lt;/b&gt;&lt;hr&gt;&lt;br&gt;Battery 19V → &lt;b&gt;IBT-2&lt;/b&gt; → Motor&lt;br&gt;&lt;br&gt;ESP32-P4 PWM = electronic trigger&lt;br&gt;duty  5% → ~1V avg → slow&lt;br&gt;duty 50% → ~9.5V avg → medium&lt;br&gt;duty 100% → 19V → full speed&lt;br&gt;&lt;br&gt;&lt;b&gt;Software-controlled drill speed&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="550" y="1450" width="280" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="drill_benefits" value="&lt;b&gt;Why This is Better:&lt;/b&gt;&lt;hr&gt;□ Programmable speed profiles&lt;br&gt;□ Remote control via Wi-Fi&lt;br&gt;□ Precise repeatability&lt;br&gt;□ Safety: software E-stop&lt;br&gt;□ Data logging (RPM, current)&lt;br&gt;□ Integration with other&lt;br&gt;   knuggets (servo pan/tilt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="870" y="1460" width="220" height="170" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
