        <!-- ==================== SECTION 2: WHAT IS PWM? ==================== -->
        <mxCell id="s2_bar" value="&lt;b&gt;2. WHAT IS PWM? — Pulse Width Modulation&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="60" y="480" width="1080" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="pwm_explain" value="&lt;b&gt;PWM doesn't reduce voltage — it switches full voltage ON and OFF very fast (25,000 times/sec).&lt;/b&gt;&lt;br&gt;The motor's inertia averages it out into smooth speed control." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="530" width="1080" height="40" as="geometry"/>
        </mxCell>

