<mxfile host="app.diagrams.net" modified="2026-03-21T00:00:00.000Z" agent="CC" version="24.0.0">
  <diagram id="flash-c6" name="Flash ESP32-C6 via FTDI">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="3200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="&lt;b&gt;How to Flash the ESP32-C6 Companion Chip via FTDI&lt;/b&gt;&lt;br&gt;Waveshare ESP32-P4-WIFI6 Kit A — esp_hosted slave firmware" style="text;html=1;align=center;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="700" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="s1" value="&lt;b&gt;1. WHY — The C6 Needs esp_hosted Slave Firmware&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="1180" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="why" value="&lt;b&gt;The ESP32-P4 has NO built-in Wi-Fi or Bluetooth.&lt;/b&gt;&lt;br&gt;&lt;br&gt;The Waveshare board has a companion &lt;b&gt;ESP32-C6&lt;/b&gt; connected via &lt;b&gt;SDIO&lt;/b&gt; bus.&lt;br&gt;The C6 runs &lt;b&gt;esp_hosted slave firmware&lt;/b&gt; — it acts as a Wi-Fi/BLE modem for the P4.&lt;br&gt;&lt;br&gt;&lt;b&gt;If C6 firmware is missing or wrong:&lt;/b&gt; → &lt;font color=&quot;#CE422B&quot;&gt;&lt;b&gt;wifi=FAIL&lt;/b&gt;&lt;/font&gt; — no SSID, no Wi-Fi AP, no SPA.&lt;br&gt;&lt;b&gt;Solution:&lt;/b&gt; Reflash C6 with esp_hosted slave firmware using FTDI serial adapter." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="130" width="700" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="arch" value="&lt;pre style=&quot;font-size:11px;&quot;&gt;┌──────────────┐   SDIO Bus    ┌──────────────┐&lt;br&gt;│  ESP32-P4    │ ◄──────────► │  ESP32-C6    │&lt;br&gt;│  (main CPU)  │  GPIO 14–19  │  (Wi-Fi/BLE) │&lt;br&gt;│  Your app    │  Reset: G54  │  esp_hosted  │&lt;br&gt;│  runs here   │              │  slave FW    │&lt;br&gt;└──────────────┘              └──────────────┘&lt;br&gt;  400MHz RISC-V                 160MHz RISC-V&lt;br&gt;  no Wi-Fi                     Wi-Fi 6 + BLE 5&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="800" y="130" width="340" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="s2" value="&lt;b&gt;2. H4 HEADER — Where to Connect FTDI (Actual Board Photos)&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="60" y="300" width="1180" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="h4_pins" value="&lt;b&gt;H4 Header — 4 Gold Pads:&lt;/b&gt;&lt;hr&gt;&lt;pre style=&quot;font-size:14px;&quot;&gt; IO9   GND   RXD   TXD &lt;br&gt;  ●     ●     ●     ●  &lt;br&gt;  │     │     │     │  &lt;br&gt;  ▼     ▼     ▼     ▼  &lt;br&gt; BOOT  GND  C6←PC PC←C6&lt;/pre&gt;&lt;br&gt;White JST connector is adjacent." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="900" y="550" width="280" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="s3" value="&lt;b&gt;3. WIRING — FTDI to H4 Header&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="60" y="1060" width="1180" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="ftdi_box" value="&lt;b&gt;FTDI USB-to-Serial&lt;/b&gt;&lt;br&gt;(3.3V — NOT 5V!)&lt;hr&gt;&lt;br&gt;&lt;b&gt;TXD&lt;/b&gt;  →  data out&lt;br&gt;&lt;b&gt;RXD&lt;/b&gt;  ←  data in&lt;br&gt;&lt;b&gt;GND&lt;/b&gt;  ─  ground&lt;br&gt;&lt;br&gt;&lt;i&gt;USB side → PC&lt;br&gt;Shows as /dev/ttyUSB0&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="60" y="1120" width="220" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="wiring_detail" value="&lt;pre style=&quot;font-size:14px;line-height:2;&quot;&gt;&lt;b&gt;FTDI            H4 Header (C6)&lt;/b&gt;&lt;br&gt;═══════         ══════════════&lt;br&gt;&lt;font color=&quot;#2D9B3A&quot;&gt;TXD  ──────────►  RXD&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#d6b656&quot;&gt;RXD  ◄──────────  TXD&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#333&quot;&gt;GND  ───────────  GND&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#CE422B&quot;&gt;&lt;b&gt;Boot mode (to flash):&lt;/b&gt;&lt;br&gt;IO9  ───────────  GND  (jumper wire)&lt;/font&gt;&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=15;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="340" y="1120" width="380" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="c6_box" value="&lt;b&gt;ESP32-C6 on Board&lt;/b&gt;&lt;br&gt;(H4 header)&lt;hr&gt;&lt;br&gt;&lt;b&gt;RXD&lt;/b&gt;  ← receives from FTDI TXD&lt;br&gt;&lt;b&gt;TXD&lt;/b&gt;  → transmits to FTDI RXD&lt;br&gt;&lt;b&gt;GND&lt;/b&gt;  ─ shared ground&lt;br&gt;&lt;b&gt;IO9&lt;/b&gt;  ─ BOOT pin:&lt;br&gt;   → GND = download mode&lt;br&gt;   → float = normal boot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="780" y="1120" width="280" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="warn" value="&lt;font color=&quot;#CE422B&quot;&gt;&lt;b&gt;⚠ TX↔RX CROSSOVER!&lt;/b&gt;  FTDI TXD → C6 RXD  |  FTDI RXD ← C6 TXD  |  ⚠ FTDI MUST BE 3.3V — 5V WILL DAMAGE C6&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="1340" width="1000" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="s4" value="&lt;b&gt;4. STEP-BY-STEP FLASH PROCEDURE&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="60" y="1400" width="1180" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="st1" value="&lt;b&gt;Step 1&lt;/b&gt;&lt;br&gt;Get Firmware&lt;hr&gt;&lt;pre style=&quot;font-size:9px;&quot;&gt;git clone --recursive \&lt;br&gt; github.com/espressif/&lt;br&gt; esp-hosted.git&lt;br&gt;cd esp-hosted/&lt;br&gt; esp_hosted_fg/esp/&lt;br&gt; esp32c6&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="60" y="1460" width="180" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="st2" value="&lt;b&gt;Step 2&lt;/b&gt;&lt;br&gt;Wire FTDI → H4&lt;hr&gt;TXD → RXD&lt;br&gt;RXD → TXD&lt;br&gt;GND → GND&lt;br&gt;IO9 → GND (jumper)&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#CE422B&quot;&gt;&lt;b&gt;⚠ 3.3V only!&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="1460" width="180" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="st3" value="&lt;b&gt;Step 3&lt;/b&gt;&lt;br&gt;Boot Mode&lt;hr&gt;Hold IO9→GND&lt;br&gt;Press RESET button&lt;br&gt;C6 enters download&lt;br&gt;&lt;br&gt;FTDI shows as&lt;br&gt;/dev/ttyUSB0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="480" y="1460" width="180" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="st4" value="&lt;b&gt;Step 4&lt;/b&gt;&lt;br&gt;Flash&lt;hr&gt;&lt;pre style=&quot;font-size:9px;&quot;&gt;source ~/esp-idf/&lt;br&gt; export.sh&lt;br&gt;&lt;br&gt;idf.py set-target&lt;br&gt; esp32c6&lt;br&gt;idf.py build&lt;br&gt;idf.py -p&lt;br&gt; /dev/ttyUSB0 flash&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="690" y="1460" width="180" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="st5" value="&lt;b&gt;Step 5&lt;/b&gt;&lt;br&gt;Verify&lt;hr&gt;Remove IO9→GND&lt;br&gt;Press RESET&lt;br&gt;Flash P4 Phase 2&lt;br&gt;&lt;br&gt;Serial should show:&lt;br&gt;&lt;font color=&quot;#2D9B3A&quot;&gt;&lt;b&gt;wifi=AP_OK&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="1460" width="180" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="ea" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333;strokeWidth=2;" edge="1" source="st1" target="st2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="eb" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333;strokeWidth=2;" edge="1" source="st2" target="st3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ec" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333;strokeWidth=2;" edge="1" source="st3" target="st4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ed" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#333;strokeWidth=2;" edge="1" source="st4" target="st5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="s5" value="&lt;b&gt;5. TROUBLESHOOTING&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="60" y="1650" width="1180" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="tshoot" value="&lt;table cellpadding=&quot;6&quot; style=&quot;font-size:11px;border-collapse:collapse;&quot;&gt;&lt;tr style=&quot;background:#1a1a1a;color:white;&quot;&gt;&lt;td&gt;&lt;b&gt;Problem&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Cause&lt;/b&gt;&lt;/td&gt;&lt;td&gt;&lt;b&gt;Fix&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8cecc;&quot;&gt;&lt;td&gt;esptool: can't connect&lt;/td&gt;&lt;td&gt;TX/RX swapped or IO9 not grounded&lt;/td&gt;&lt;td&gt;Swap TX↔RX, verify IO9→GND&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;esptool: wrong chip&lt;/td&gt;&lt;td&gt;FTDI connected to P4 not C6&lt;/td&gt;&lt;td&gt;Use H4 header, not main USB&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8cecc;&quot;&gt;&lt;td&gt;wifi=FAIL after flash&lt;/td&gt;&lt;td&gt;Wrong firmware version&lt;/td&gt;&lt;td&gt;Match esp_hosted to ESP-IDF version&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C6 not responding&lt;/td&gt;&lt;td&gt;IO9 jumper still connected&lt;/td&gt;&lt;td&gt;Remove jumper, press RESET&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;background:#f8cecc;&quot;&gt;&lt;td&gt;FTDI not detected&lt;/td&gt;&lt;td&gt;Driver missing&lt;/td&gt;&lt;td&gt;Check dmesg, install ftdi_sio&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="60" y="1700" width="700" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="s6" value="&lt;b&gt;6. COPY-PASTE COMMANDS&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="60" y="1910" width="1180" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="cmds" value="&lt;pre style=&quot;font-size:11px;line-height:1.6;color:#2D9B3A;&quot;&gt;&lt;b&gt;# 1. Activate ESP-IDF&lt;/b&gt;&lt;br&gt;source ~/Dropbox/scottsoft_sdn/esp-idf/export.sh&lt;br&gt;&lt;br&gt;&lt;b&gt;# 2. Clone esp_hosted&lt;/b&gt;&lt;br&gt;git clone --recursive https://github.com/espressif/esp-hosted.git&lt;br&gt;cd esp-hosted/esp_hosted_fg/esp/esp32c6&lt;br&gt;&lt;br&gt;&lt;b&gt;# 3. Build C6 slave firmware&lt;/b&gt;&lt;br&gt;idf.py set-target esp32c6&lt;br&gt;idf.py build&lt;br&gt;&lt;br&gt;&lt;b&gt;# 4. Flash (IO9 must be grounded!)&lt;/b&gt;&lt;br&gt;idf.py -p /dev/ttyUSB0 flash&lt;br&gt;&lt;br&gt;&lt;b&gt;# 5. Remove IO9→GND jumper, press RESET&lt;/b&gt;&lt;br&gt;&lt;b&gt;# 6. Flash P4 Phase 2, check wifi=AP_OK&lt;/b&gt;&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0D0D1A;strokeColor=#2D9B3A;fontSize=10;align=left;spacingLeft=10;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="60" y="1960" width="600" height="250" as="geometry"/>
        </mxCell>

        <mxCell id="anki" value="&lt;b&gt;Anki-Ref:&lt;/b&gt; 20260320_XXXXXX__esp32-p4-wifi6-kit-a__flash_c6_with_ftdi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#ffffff;strokeColor=#1a1a1a;fontSize=11;align=left;spacingLeft=15;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="2240" width="550" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="embedded_img_0_label" value="&lt;b&gt;img_20260321_072737&lt;/b&gt;" style="text;html=1;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="350" width="785" height="20" as="geometry"/>
        </mxCell>
