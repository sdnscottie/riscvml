        </mxCell>

        <mxCell id="embedded_img_0_label" value="&lt;b&gt;img_20260321_075209&lt;/b&gt;" style="text;html=1;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="1850" width="1186" height="20" as="geometry"/>
        </mxCell>
