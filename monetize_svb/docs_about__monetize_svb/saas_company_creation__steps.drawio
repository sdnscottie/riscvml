<mxfile host="app.diagrams.net" modified="2026-03-18T00:00:00.000Z" agent="Claude Code" version="24.0.0">
  <diagram id="saas-creation" name="Creating a Small SaaS Company">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="2800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ==================== TITLE ==================== -->
        <mxCell id="title" value="&lt;b&gt;Creating a Small SaaS Company — From Idea to Revenue&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="&lt;i&gt;Solo founder / small team playbook — riscvml.org &amp; agrarobotics.com context&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="450" y="55" width="500" height="25" as="geometry"/>
        </mxCell>

        <!-- ==================== PHASE 0: THE IDEA ==================== -->
        <mxCell id="ph0_bar" value="&lt;b&gt;PHASE 0 — THE IDEA&lt;/b&gt;  (Week 0)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="1200" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="ph0_1" value="&lt;b&gt;Identify a Pain&lt;/b&gt;&lt;br&gt;Not a &quot;cool feature&quot; — a real&lt;br&gt;problem people pay to solve.&lt;br&gt;&lt;i&gt;Best ideas come from your&lt;br&gt;own domain frustrations.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="155" width="220" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="ph0_2" value="&lt;b&gt;One-Liner Test&lt;/b&gt;&lt;br&gt;Can you explain it in one sentence?&lt;br&gt;&lt;i&gt;&quot;[Product] helps [who] do [what]&lt;br&gt;so they can [outcome].&quot;&lt;/i&gt;&lt;br&gt;If you can't → too vague." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="155" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="ph0_3" value="&lt;b&gt;Quick Sanity Check&lt;/b&gt;&lt;br&gt;□ Can I build this? (tech feasibility)&lt;br&gt;□ Would I use this myself?&lt;br&gt;□ Can I reach the buyers? (channel)&lt;br&gt;□ Can it generate recurring revenue?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="155" width="280" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="ph0_trap" value="&lt;b&gt;TRAP: &quot;I'll just build it&quot;&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;Do NOT skip to coding.&lt;br&gt;Validate first. Always.&lt;/font&gt;&lt;br&gt;(see: idea_validation diagram)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="155" width="220" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="e_ph0_1_2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ph0_1" target="ph0_2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ph0_2_3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ph0_2" target="ph0_3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ph0_3_trap" style="edgeStyle=orthogonalEdgeStyle;dashed=1;strokeColor=#b85450;" edge="1" source="ph0_3" target="ph0_trap" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== PHASE 1: VALIDATE ==================== -->
        <mxCell id="ph1_bar" value="&lt;b&gt;PHASE 1 — VALIDATE&lt;/b&gt;  (Weeks 1–4)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9673a6;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="100" y="290" width="1200" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="ph1_1" value="&lt;b&gt;1. Waiting List Campaign&lt;/b&gt;&lt;hr&gt;Landing page (Carrd / Framer)&lt;br&gt;+ Email capture + Questionnaire&lt;br&gt;(Tally / Typeform / Google Forms)&lt;br&gt;&lt;br&gt;&lt;b&gt;Ask:&lt;/b&gt; role, pain point, urgency,&lt;br&gt;current solution, budget range&lt;br&gt;&lt;br&gt;&lt;i&gt;Run for 2+ ideas in parallel.&lt;br&gt;Let the numbers pick the winner.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="345" width="260" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="ph1_2" value="&lt;b&gt;2. Problem Interviews&lt;/b&gt;&lt;hr&gt;Talk to 15–20 people from waitlist&lt;br&gt;&lt;br&gt;&lt;b&gt;Questions:&lt;/b&gt;&lt;br&gt;• &quot;How do you solve this today?&quot;&lt;br&gt;• &quot;What's the worst part?&quot;&lt;br&gt;• &quot;How much time/money does&lt;br&gt;   this problem cost you?&quot;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;&lt;b&gt;Don't pitch. Just listen.&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="345" width="250" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="ph1_3" value="&lt;b&gt;3. Decision Gate&lt;/b&gt;&lt;hr&gt;&lt;font color=&quot;#82b366&quot;&gt;&lt;b&gt;GO signals:&lt;/b&gt;&lt;/font&gt;&lt;br&gt;• 500+ waitlist sign-ups&lt;br&gt;• 70%+ confirm the pain is real&lt;br&gt;• People describe the problem&lt;br&gt;  using the same words&lt;br&gt;• Someone says &quot;I'd pay for that&quot;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;&lt;b&gt;KILL signals:&lt;/b&gt;&lt;/font&gt;&lt;br&gt;• &lt;100 sign-ups despite promotion&lt;br&gt;• &quot;Nice to have&quot; not &quot;must have&quot;&lt;br&gt;• No willingness to pay" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="345" width="260" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="ph1_cost" value="&lt;b&gt;Total cost of Phase 1:&lt;/b&gt;&lt;br&gt;$0–$150 (domain + small ad spend)&lt;br&gt;+ 20 hours of your time&lt;br&gt;&lt;br&gt;&lt;b&gt;What you saved:&lt;/b&gt;&lt;br&gt;3–6 months building something&lt;br&gt;nobody wants" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="930" y="345" width="240" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="e_ph1_1_2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ph1_1" target="ph1_2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ph1_2_3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ph1_2" target="ph1_3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== PHASE 2: MVP ==================== -->
        <mxCell id="ph2_bar" value="&lt;b&gt;PHASE 2 — BUILD THE MVP&lt;/b&gt;  (Weeks 5–10)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d6b656;fontColor=#1a1a1a;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="100" y="600" width="1200" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="ph2_rule" value="&lt;b&gt;THE MVP RULE:&lt;/b&gt; Build ONLY the thing that solves the #1 pain from your interviews. Nothing else." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="100" y="650" width="700" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="ph2_stack" value="&lt;b&gt;Pick a Boring Stack&lt;/b&gt;&lt;hr&gt;&lt;b&gt;Frontend:&lt;/b&gt; Next.js / SvelteKit / plain HTML&lt;br&gt;&lt;b&gt;Backend:&lt;/b&gt; Rust (Axum) / Node / Rails&lt;br&gt;&lt;b&gt;DB:&lt;/b&gt; SQLite → Postgres when needed&lt;br&gt;&lt;b&gt;Auth:&lt;/b&gt; Clerk / Auth.js / Supabase Auth&lt;br&gt;&lt;b&gt;Payments:&lt;/b&gt; Stripe (always Stripe)&lt;br&gt;&lt;b&gt;Deploy:&lt;/b&gt; Fly.io / Railway / VPS&lt;br&gt;&lt;br&gt;&lt;i&gt;Use what you know. Speed &gt; perfection.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="705" width="260" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="ph2_features" value="&lt;b&gt;MVP Feature Scope&lt;/b&gt;&lt;hr&gt;&lt;b&gt;Must have (ship these):&lt;/b&gt;&lt;br&gt;□ Core value feature (the ONE thing)&lt;br&gt;□ User sign-up / login&lt;br&gt;□ Stripe payment integration&lt;br&gt;□ Basic dashboard&lt;br&gt;&lt;br&gt;&lt;b&gt;Cut ruthlessly:&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;✗ Admin panel (use DB directly)&lt;br&gt;✗ Teams / orgs (add later)&lt;br&gt;✗ Mobile app (responsive web)&lt;br&gt;✗ Custom domains&lt;br&gt;✗ Analytics dashboard&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="705" width="260" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="ph2_pricing" value="&lt;b&gt;Pricing (Day 1)&lt;/b&gt;&lt;hr&gt;&lt;b&gt;Start simple — 2 tiers max:&lt;/b&gt;&lt;br&gt;&lt;br&gt;FREE — limited usage&lt;br&gt;(waitlist converts → free tier)&lt;br&gt;&lt;br&gt;PRO $X/mo — full access&lt;br&gt;(price from interview data:&lt;br&gt;&quot;How much would you pay?&quot;)&lt;br&gt;&lt;br&gt;&lt;b&gt;Anchor high, discount early.&lt;/b&gt;&lt;br&gt;&lt;i&gt;You can always lower price.&lt;br&gt;Raising price is painful.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="660" y="705" width="250" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="ph2_legal" value="&lt;b&gt;Legal / Business Setup&lt;/b&gt;&lt;hr&gt;□ Register company&lt;br&gt;   (GmbH in DE / LLC in US)&lt;br&gt;□ Business bank account&lt;br&gt;□ Stripe account&lt;br&gt;□ Domain + professional email&lt;br&gt;□ Privacy policy (GDPR if EU)&lt;br&gt;□ Terms of service&lt;br&gt;&lt;br&gt;&lt;i&gt;Don't over-invest here yet.&lt;br&gt;Stripe Atlas or Firstbase&lt;br&gt;can handle most of this.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="930" y="705" width="240" height="220" as="geometry"/>
        </mxCell>

        <!-- ==================== PHASE 3: LAUNCH ==================== -->
        <mxCell id="ph3_bar" value="&lt;b&gt;PHASE 3 — LAUNCH &amp; FIRST CUSTOMERS&lt;/b&gt;  (Weeks 10–14)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#82b366;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="100" y="960" width="1200" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="ph3_1" value="&lt;b&gt;1. Soft Launch to Waitlist&lt;/b&gt;&lt;hr&gt;Email your waitlist:&lt;br&gt;&quot;You signed up — it's ready.&quot;&lt;br&gt;&lt;br&gt;Offer founding member pricing&lt;br&gt;(e.g. 50% off forever)&lt;br&gt;&lt;br&gt;&lt;b&gt;Goal: 10 paying customers&lt;/b&gt;&lt;br&gt;&lt;i&gt;Not 10,000. Just 10 who pay.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1015" width="250" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="ph3_2" value="&lt;b&gt;2. Concierge Onboarding&lt;/b&gt;&lt;hr&gt;Personally onboard every&lt;br&gt;early customer. 1:1 calls.&lt;br&gt;&lt;br&gt;&lt;b&gt;Watch them use it.&lt;/b&gt;&lt;br&gt;Where do they get stuck?&lt;br&gt;What do they ask for?&lt;br&gt;&lt;br&gt;&lt;i&gt;This is your best product&lt;br&gt;research. It doesn't scale.&lt;br&gt;That's the point.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="1015" width="250" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="ph3_3" value="&lt;b&gt;3. Public Launch&lt;/b&gt;&lt;hr&gt;Once 10 paying + feedback loop:&lt;br&gt;&lt;br&gt;□ Product Hunt launch&lt;br&gt;□ Hacker News &quot;Show HN&quot;&lt;br&gt;□ Reddit (relevant subreddits)&lt;br&gt;□ X / LinkedIn post with demo&lt;br&gt;□ Indie Hackers community&lt;br&gt;&lt;br&gt;&lt;b&gt;Tip:&lt;/b&gt; Launch multiple times.&lt;br&gt;Nobody remembers the first one." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="1015" width="250" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="ph3_metrics" value="&lt;b&gt;Key Metrics to Track&lt;/b&gt;&lt;hr&gt;&lt;b&gt;MRR&lt;/b&gt; — Monthly Recurring Revenue&lt;br&gt;&lt;b&gt;Churn&lt;/b&gt; — % who cancel per month&lt;br&gt;&lt;b&gt;CAC&lt;/b&gt; — Cost to Acquire a Customer&lt;br&gt;&lt;b&gt;LTV&lt;/b&gt; — Lifetime Value per customer&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#82b366&quot;&gt;&lt;b&gt;Healthy:&lt;/b&gt; LTV &gt; 3x CAC&lt;br&gt;Churn &lt; 5%/month&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;&lt;b&gt;Danger:&lt;/b&gt; LTV &lt; CAC = losing money&lt;br&gt;Churn &gt; 10% = leaky bucket&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="910" y="1015" width="260" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="e_ph3_1_2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ph3_1" target="ph3_2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ph3_2_3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="ph3_2" target="ph3_3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== PHASE 4: GROW ==================== -->
        <mxCell id="ph4_bar" value="&lt;b&gt;PHASE 4 — GROW TO SUSTAINABLE REVENUE&lt;/b&gt;  (Months 4–12)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6c8ebf;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="100" y="1260" width="1200" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="ph4_1" value="&lt;b&gt;Content / SEO Engine&lt;/b&gt;&lt;hr&gt;Write content that answers&lt;br&gt;the questions your customers ask.&lt;br&gt;&lt;br&gt;□ Blog posts (solve real problems)&lt;br&gt;□ Comparison pages (vs competitors)&lt;br&gt;□ Tutorial / how-to pages&lt;br&gt;□ YouTube walkthroughs&lt;br&gt;&lt;br&gt;&lt;i&gt;SEO is slow but compounds.&lt;br&gt;Start in month 1, harvest by month 6.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1315" width="260" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="ph4_2" value="&lt;b&gt;Community &amp; Word of Mouth&lt;/b&gt;&lt;hr&gt;□ Discord / forum for users&lt;br&gt;□ Public changelog (/changelog)&lt;br&gt;□ Feature voting board&lt;br&gt;□ Referral program&lt;br&gt;□ Showcase customer wins&lt;br&gt;&lt;br&gt;&lt;b&gt;Best growth = happy users&lt;br&gt;telling other people.&lt;/b&gt;&lt;br&gt;&lt;i&gt;Nothing beats organic WOM.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="1315" width="260" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="ph4_3" value="&lt;b&gt;Iterate on Product&lt;/b&gt;&lt;hr&gt;Ship weekly. Small releases.&lt;br&gt;&lt;br&gt;&lt;b&gt;Feature priority =&lt;/b&gt;&lt;br&gt;What paying customers ask for&lt;br&gt;(NOT what free users want)&lt;br&gt;&lt;br&gt;&lt;b&gt;Build in public:&lt;/b&gt;&lt;br&gt;Share revenue, learnings, wins&lt;br&gt;on X / LinkedIn / Indie Hackers&lt;br&gt;&lt;br&gt;&lt;i&gt;Transparency builds trust.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="660" y="1315" width="250" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="ph4_milestones" value="&lt;b&gt;Revenue Milestones&lt;/b&gt;&lt;hr&gt;&lt;b&gt;$0 → $100 MRR&lt;/b&gt;&lt;br&gt;Proof someone will pay.&lt;br&gt;&lt;br&gt;&lt;b&gt;$100 → $1K MRR&lt;/b&gt;&lt;br&gt;Repeatable acquisition.&lt;br&gt;&lt;br&gt;&lt;b&gt;$1K → $5K MRR&lt;/b&gt;&lt;br&gt;Covers basic costs. Real business.&lt;br&gt;&lt;br&gt;&lt;b&gt;$5K → $10K MRR&lt;/b&gt;&lt;br&gt;Ramen profitable. Can quit day job.&lt;br&gt;&lt;br&gt;&lt;b&gt;$10K+ MRR&lt;/b&gt;&lt;br&gt;Sustainable. Consider hiring." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="930" y="1315" width="240" height="260" as="geometry"/>
        </mxCell>

        <!-- ==================== PHASE 5: SUSTAIN ==================== -->
        <mxCell id="ph5_bar" value="&lt;b&gt;PHASE 5 — SUSTAIN &amp; DECIDE&lt;/b&gt;  (Year 1+)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1a1a;fontColor=#ffffff;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="100" y="1610" width="1200" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="ph5_paths" value="&lt;b&gt;Three Paths Forward&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontColor=#1a1a1a;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="1660" width="200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="ph5_lifestyle" value="&lt;b&gt;A. Lifestyle Business&lt;/b&gt;&lt;hr&gt;Stay small, stay profitable.&lt;br&gt;Solo or 2–3 people.&lt;br&gt;$10K–$50K MRR.&lt;br&gt;&lt;br&gt;Optimize for freedom:&lt;br&gt;time, location, autonomy.&lt;br&gt;&lt;br&gt;&lt;i&gt;Most SaaS founders choose this.&lt;br&gt;It's underrated.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1710" width="250" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="ph5_grow" value="&lt;b&gt;B. Growth Company&lt;/b&gt;&lt;hr&gt;Hire a team. Raise funding&lt;br&gt;or bootstrap aggressively.&lt;br&gt;Target $100K+ MRR.&lt;br&gt;&lt;br&gt;Higher stress, higher ceiling.&lt;br&gt;&lt;br&gt;&lt;i&gt;Only if the market is big&lt;br&gt;enough to justify it.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="1710" width="250" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="ph5_exit" value="&lt;b&gt;C. Sell / Exit&lt;/b&gt;&lt;hr&gt;Sell on Acquire.com, MicroAcquire&lt;br&gt;or via broker.&lt;br&gt;&lt;br&gt;Typical multiples:&lt;br&gt;3–5x annual profit (small)&lt;br&gt;5–10x ARR (growth)&lt;br&gt;&lt;br&gt;&lt;i&gt;Build to sell = build&lt;br&gt;something someone else wants.&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="660" y="1710" width="250" height="180" as="geometry"/>
        </mxCell>

        <!-- ==================== TIMELINE SUMMARY ==================== -->
        <mxCell id="timeline_bar" value="&lt;b&gt;TIMELINE SUMMARY&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=14;align=left;spacingLeft=20;" vertex="1" parent="1">
          <mxGeometry x="100" y="1940" width="1200" height="35" as="geometry"/>
        </mxCell>

